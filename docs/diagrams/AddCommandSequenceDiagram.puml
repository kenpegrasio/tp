@startuml
skinparam monochrome true
skinparam shadowing false
hide footbox

box "Logic" #LightBlue
participant "<<class>>\nParser" as Parser
participant "d:AddCommand" as AddCommand
participant "v:AddCommandValidator" as AddCommandValidator
participant "dup:DuplicateItemValidator" as DuplicateItemValidator
end box

box "Data" #LightYellow
participant "items:ItemList" as ItemList
participant "categories:CategoryList" as CategoryList
participant "newItem:Item" as Item
end box

box "UI" #LightGreen
participant "ui:Ui" as Ui
end box

-> Parser : parse("addItem d/Apple q/10 p/1.50 c/Others", items, categories, ui)
activate Parser

create AddCommand
Parser -> AddCommand : new AddCommand("addItem d/Apple q/10 p/1.50 c/Others")
activate AddCommand
AddCommand --> Parser : d
deactivate AddCommand

Parser -> AddCommand : execute(items, categories, ui)
activate AddCommand

create AddCommandValidator
AddCommand -> AddCommandValidator : new AddCommandValidator("addItem d/Apple q/10 p/1.50 c/Others")
activate AddCommandValidator
AddCommandValidator --> AddCommand : v
deactivate AddCommandValidator

AddCommand -> AddCommandValidator : validate(items, categories)
activate AddCommandValidator

note right of AddCommandValidator
  Applies regex:
  ^addItem\s+d/(.+?)\s+q/(\d+)\s+p/(\d+(\.\d+)?)\s+c/(.+)$
  Checks in order:
  1. name contains d/, q/, or p/ → "Duplicate parameter detected."
  2. name.isEmpty() → "Item name cannot be empty."
  3. name.contains("'") → "Item description cannot contain single quotes."
  4. DuplicateItemValidator (case-insensitive name check)
  5. Integer overflow on quantity → "Quantity is too large..."
  6. quantity < 0 → "Quantity cannot be negative."
  7. price is Infinity → "Price is too large..."
  8. Math.round(price * 100) <= 0 → "Price must be at least 0.01 when rounded"
  9. category not in CategoryList → "The category [...] does not exist!"
end note

create DuplicateItemValidator
AddCommandValidator -> DuplicateItemValidator : new DuplicateItemValidator("Apple")
activate DuplicateItemValidator
DuplicateItemValidator --> AddCommandValidator : dv
deactivate DuplicateItemValidator

AddCommandValidator -> DuplicateItemValidator : validate(items, categories)
activate DuplicateItemValidator

loop for each item in ItemList
    DuplicateItemValidator -> ItemList : getItem(i)
    activate ItemList
    ItemList --> DuplicateItemValidator : item
    deactivate ItemList
    note right of DuplicateItemValidator
        item.getDescription().equalsIgnoreCase("Apple")
    end note
end

DuplicateItemValidator --> AddCommandValidator
deactivate DuplicateItemValidator
DuplicateItemValidator -[hidden]-> AddCommandValidator
destroy DuplicateItemValidator

AddCommandValidator --> AddCommand
deactivate AddCommandValidator
AddCommandValidator -[hidden]-> AddCommand
destroy AddCommandValidator

note right of AddCommand
  Re-applies regex to extract:
  name         = group(1).trim()
  quantity     = Integer.parseInt(group(2))
  price        = Double.parseDouble(group(3))
  categoryName = group(5).trim()
end note

AddCommand -> CategoryList : getCategory("Others")
activate CategoryList
CategoryList --> AddCommand : targetCategory
deactivate CategoryList

create Item
AddCommand -> Item : new Item("Apple", 10, 1.50, targetCategory)
activate Item
Item --> AddCommand : newItem
deactivate Item

AddCommand -> ItemList : addItem(newItem)
activate ItemList
ItemList --> AddCommand
deactivate ItemList

AddCommand -> Ui : showMessage("Added: [OTHERS] Apple (Quantity: 10, Price: $1.50)")
activate Ui
Ui --> AddCommand
deactivate Ui

AddCommand --> Parser
deactivate AddCommand
AddCommand -[hidden]-> Parser
destroy AddCommand

<-- Parser
deactivate Parser

@enduml

@startuml
skinparam monochrome true
skinparam shadowing false
hide footbox

box "Logic" #LightBlue
participant "<<class>>\nParser" as Parser
participant "d:EditPriceCommand" as EditPriceCommand
participant "v:EditPriceCommandValidator" as EditPriceCommandValidator
end box

box "Data" #LightYellow
participant "items:ItemList" as ItemList
participant "item:Item" as Item
end box

box "UI" #LightGreen
participant "ui:Ui" as Ui
end box

-> Parser : parse("editPrice 1 p/2.50", items, ui)
activate Parser

create EditPriceCommand
Parser -> EditPriceCommand : new EditPriceCommand(input)
activate EditPriceCommand
EditPriceCommand --> Parser : d
deactivate EditPriceCommand

Parser -> EditPriceCommand : execute(items, ui)
activate EditPriceCommand

create EditPriceCommandValidator
EditPriceCommand -> EditPriceCommandValidator : new EditPriceCommandValidator(input)
activate EditPriceCommandValidator
EditPriceCommandValidator --> EditPriceCommand : v
deactivate EditPriceCommandValidator

EditPriceCommand -> EditPriceCommandValidator : validate(items)
activate EditPriceCommandValidator
note right of EditPriceCommandValidator
  Checks format, index bounds,
  and non-negative price
end note
EditPriceCommandValidator --> EditPriceCommand
deactivate EditPriceCommandValidator
EditPriceCommandValidator -[hidden]-> EditPriceCommand
destroy EditPriceCommandValidator

EditPriceCommand -> ItemList : getItem(index)
activate ItemList
ItemList --> EditPriceCommand : item
deactivate ItemList

EditPriceCommand -> Item : setPrice(newPrice)
activate Item
Item --> EditPriceCommand
deactivate Item

EditPriceCommand -> Ui : showMessage("Item price updated: " + item)
activate Ui
Ui --> EditPriceCommand
deactivate Ui

EditPriceCommand --> Parser
deactivate EditPriceCommand
EditPriceCommand -[hidden]-> Parser
destroy EditPriceCommand

<-- Parser
deactivate Parser

@enduml

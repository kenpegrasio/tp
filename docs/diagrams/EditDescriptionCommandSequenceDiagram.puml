@startuml
skinparam monochrome true
skinparam shadowing false
hide footbox

box "Logic" #LightBlue
participant "<<class>>\nParser" as Parser
participant "d:EditDescriptionCommand" as EditDescriptionCommand
participant "v:EditDescriptionCommandValidator" as EditDescriptionCommandValidator
end box

box "Data" #LightYellow
participant "items:ItemList" as ItemList
participant "item:Item" as Item
end box

box "UI" #LightGreen
participant "ui:Ui" as Ui
end box

-> Parser : parse("editDescription 1 d/New Name", items, ui)
activate Parser

create EditDescriptionCommand
Parser -> EditDescriptionCommand : new EditDescriptionCommand(input)
activate EditDescriptionCommand
EditDescriptionCommand --> Parser : d
deactivate EditDescriptionCommand

Parser -> EditDescriptionCommand : execute(items, ui)
activate EditDescriptionCommand

create EditDescriptionCommandValidator
EditDescriptionCommand -> EditDescriptionCommandValidator : new EditDescriptionCommandValidator(input)
activate EditDescriptionCommandValidator
EditDescriptionCommandValidator --> EditDescriptionCommand : v
deactivate EditDescriptionCommandValidator

EditDescriptionCommand -> EditDescriptionCommandValidator : validate(items)
activate EditDescriptionCommandValidator
note right of EditDescriptionCommandValidator
  Checks format, index bounds,
  and non-empty description
end note
EditDescriptionCommandValidator --> EditDescriptionCommand
deactivate EditDescriptionCommandValidator
EditDescriptionCommandValidator -[hidden]-> EditDescriptionCommand
destroy EditDescriptionCommandValidator

EditDescriptionCommand -> ItemList : getItem(index)
activate ItemList
ItemList --> EditDescriptionCommand : item
deactivate ItemList

EditDescriptionCommand -> Item : setDescription(newDescription)
activate Item
Item --> EditDescriptionCommand
deactivate Item

EditDescriptionCommand -> Ui : showMessage("Item description updated: " + item)
activate Ui
Ui --> EditDescriptionCommand
deactivate Ui

EditDescriptionCommand --> Parser
deactivate EditDescriptionCommand
EditDescriptionCommand -[hidden]-> Parser
destroy EditDescriptionCommand

<-- Parser
deactivate Parser

@enduml

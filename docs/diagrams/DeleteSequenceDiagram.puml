@startuml
!pragma teoz true
skinparam monochrome true
skinparam shadowing false

box "Logic" #LightBlue
participant "<<class>>\nParser" as Parser
participant "d:DeleteCommand" as DeleteCommand
participant "v:DeleteCommandValidator" as DeleteCommandValidator
end box

box "Data" #LightYellow
participant "items:ItemList" as ItemList
end box

box "UI" #LightGreen
participant "ui:Ui" as Ui
end box

-> Parser : parse("deleteItem 1", items, ui)
activate Parser

create DeleteCommand
Parser -> DeleteCommand : new DeleteCommand("deleteItem 1")
activate DeleteCommand
DeleteCommand --> Parser : d
deactivate DeleteCommand

Parser -> DeleteCommand : execute(items, ui)
activate DeleteCommand

create DeleteCommandValidator
DeleteCommand -> DeleteCommandValidator : new DeleteCommandValidator("deleteItem 1")
activate DeleteCommandValidator
DeleteCommandValidator --> DeleteCommand : v
deactivate DeleteCommandValidator

DeleteCommand -> DeleteCommandValidator : validate(items)
activate DeleteCommandValidator
DeleteCommandValidator --> DeleteCommand
deactivate DeleteCommandValidator

DeleteCommand -> ItemList : deleteItem(0)
activate ItemList
ItemList --> DeleteCommand : removedItem
deactivate ItemList

DeleteCommand -> Ui : showMessage("Noted, BRO...")
activate Ui
Ui --> DeleteCommand
deactivate Ui

DeleteCommand --> Parser
deactivate DeleteCommand

<-- Parser
deactivate Parser

@enduml